  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": {
        "offsetX": 0,
        "offsetY": 1,
        "blur": 2,
        "color": "#1b2532",
        "opacity": 0.05
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "offsetX": 0,
        "offsetY": 4,
        "blur": 12,
        "color": "#1b2532",
        "opacity": 0.08
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": 0,
        "offsetY": 12,
        "blur": 40,
        "color": "#1b2532",
        "opacity": 0.12
      }
    },
    "xl": {
      "$type": "shadow",
      "$value": {
        "offsetX": 0,
        "offsetY": 24,
        "blur": 60,
        "color": "#1b2532",
        "opacity": 0.16
      }
    },
    "focus": {
      "$type": "shadow",
      "$value": {
        "offsetX": 0,
        "offsetY": 0,
        "blur": 0,
        "spread": 3,
        "color": "#4a7195",
        "opacity": 0.3
      }
    }
  },
