{
  "$schema": "https://design-tokens.ietf.org/schemas/tokens/v1/schema.json",
  "description": "ARCTIC OCEAN Design System — Light: Arctic Frost · Dark: Ocean Depths",
  "version": "1.0.0",
  "source": "src/styles/design-tokens.css",

  "color": {
    "primary": {
      "50": { "$type": "color", "$value": "#e1e9f4", "description": "Light steel blue" },
      "100": { "$type": "color", "$value": "#cde0f5", "description": "Ice blue" },
      "200": { "$type": "color", "$value": "#b0c9e6", "description": "Powder blue" },
      "300": { "$type": "color", "$value": "#8eafd4", "description": "Soft steel" },
      "400": { "$type": "color", "$value": "#2d5386", "description": "Steel blue — CTA default" },
      "500": { "$type": "color", "$value": "#274268", "description": "Deep steel" },
      "600": { "$type": "color", "$value": "#1b3054", "description": "Navy steel" },
      "700": { "$type": "color", "$value": "#152645", "description": "Dark navy" },
      "800": { "$type": "color", "$value": "#0e1d39", "description": "Very dark navy" },
      "900": { "$type": "color", "$value": "#08122b", "description": "Near-black navy" },
      "950": { "$type": "color", "$value": "#040d1a", "description": "Deepest navy" }
    },
    "surface": {
      "background": {
        "$type": "color",
        "$value": "#f9fafb",
        "description": "Page background (light)"
      },
      "elevated": {
        "$type": "color",
        "$value": "#ffffff",
        "description": "Cards, modals, dropdowns"
      },
      "sunken": { "$type": "color", "$value": "#f4f5f7", "description": "Sunken sections" },
      "highlight": {
        "$type": "color",
        "$value": "#d3e4f8",
        "description": "Tag, code, subtle highlight"
      },
      "inset": { "$type": "color", "$value": "#eaedf0", "description": "Inputs, inset areas" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#1b2532", "description": "Headings, body" },
      "secondary": { "$type": "color", "$value": "#404a59", "description": "Supporting text" },
      "tertiary": { "$type": "color", "$value": "#394656", "description": "Captions, meta" },
      "muted": { "$type": "color", "$value": "#4f5f72", "description": "Placeholder, disabled" },
      "on-primary": {
        "$type": "color",
        "$value": "#ffffff",
        "description": "Text on CTA / primary fills"
      },
      "link": { "$type": "color", "$value": "#2d4d76", "description": "Interactive links" },
      "link-hover": { "$type": "color", "$value": "#243d5c", "description": "Link hover state" }
    },
    "semantic": {
      "success": { "$type": "color", "$value": "#206e6e", "description": "Positive / success" },
      "warning": { "$type": "color", "$value": "#a59168", "description": "Warning / caution" },
      "emergency": { "$type": "color", "$value": "#a45d60", "description": "Error / danger" },
      "info": { "$type": "color", "$value": "#4a7195", "description": "Informational" }
    },
    "border": {
      "default": { "$type": "color", "$value": "#c5ccd6", "description": "Default border" },
      "subtle": { "$type": "color", "$value": "#eaeef2", "description": "Subtle divider" },
      "focus": { "$type": "color", "$value": "#4a7195", "description": "Focus ring" }
    },
    "terminal": {
      "bg": { "$type": "color", "$value": "#eaedf0", "description": "Terminal background" },
      "text": { "$type": "color", "$value": "#1b2532", "description": "Terminal text" },
      "prompt": { "$type": "color", "$value": "#4a7195", "description": "Prompt prefix" },
      "cursor": { "$type": "color", "$value": "#4a7195", "description": "Cursor" },
      "comment": { "$type": "color", "$value": "#5c6878", "description": "Comments" },
      "keyword": { "$type": "color", "$value": "#2a4a6e", "description": "Keywords" },
      "string": { "$type": "color", "$value": "#326060", "description": "Strings" }
    }
  },

  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": { "offsetX": 0, "offsetY": 1, "blur": 2, "color": "#1b2532", "opacity": 0.05 }
    },
    "md": {
      "$type": "shadow",
      "$value": { "offsetX": 0, "offsetY": 4, "blur": 12, "color": "#1b2532", "opacity": 0.08 }
    },
    "lg": {
      "$type": "shadow",
      "$value": { "offsetX": 0, "offsetY": 12, "blur": 40, "color": "#1b2532", "opacity": 0.12 }
    },
    "xl": {
      "$type": "shadow",
      "$value": { "offsetX": 0, "offsetY": 24, "blur": 60, "color": "#1b2532", "opacity": 0.16 }
    },
    "focus": {
      "$type": "shadow",
      "$value": {
        "offsetX": 0,
        "offsetY": 0,
        "blur": 0,
        "spread": 3,
        "color": "#4a7195",
        "opacity": 0.3
      }
    }
  },

  "fontFamily": {
    "sans": {
      "$type": "fontFamily",
      "$value": ["Geist", "system-ui", "-apple-system", "sans-serif"]
    },
    "mono": {
      "$type": "fontFamily",
      "$value": ["Geist Mono", "ui-monospace", "SF Mono", "monospace"]
    },
    "code": {
      "$type": "fontFamily",
      "$value": ["JetBrains Mono", "ui-monospace", "SF Mono", "monospace"]
    }
  },

  "fontSize": {
    "display": {
      "$type": "string",
      "$value": "clamp(2.5rem, 5vw, 4rem)",
      "description": "CSS clamp() — responsive"
    },
    "h1": {
      "$type": "string",
      "$value": "clamp(2rem, 4vw, 3rem)",
      "description": "CSS clamp() — responsive"
    },
    "h2": {
      "$type": "string",
      "$value": "clamp(1.5rem, 3vw, 2.25rem)",
      "description": "CSS clamp() — responsive"
    },
    "h3": { "$type": "dimension", "$value": "1.25rem" },
    "h4": { "$type": "dimension", "$value": "1.125rem" },
    "body-lg": { "$type": "dimension", "$value": "1.125rem" },
    "body": { "$type": "dimension", "$value": "1rem" },
    "body-sm": { "$type": "dimension", "$value": "0.875rem" },
    "caption": { "$type": "dimension", "$value": "0.75rem" },
    "mono-sm": { "$type": "dimension", "$value": "0.8125rem" },
    "mono-lg": { "$type": "dimension", "$value": "0.9375rem" }
  },
  "cta": {
    "default": {
      "$type": "color",
      "$value": "#2d5386",
      "description": "Call-to-action fills — primary.400, same in both modes"
    }
  },

  "spacing": {
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "6": { "$type": "dimension", "$value": "1.5rem" },
    "8": { "$type": "dimension", "$value": "2rem" },
    "12": { "$type": "dimension", "$value": "3rem" },
    "16": { "$type": "dimension", "$value": "4rem" },
    "20": { "$type": "dimension", "$value": "5rem" },
    "24": { "$type": "dimension", "$value": "6rem" }
  },

  "borderRadius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "xl": { "$type": "dimension", "$value": "16px" },
    "2xl": { "$type": "dimension", "$value": "20px" },
    "full": { "$type": "dimension", "$value": "9999px" },
    "interactive": { "$type": "dimension", "$value": "9999px" }
  },

  "duration": {
    "fast": { "$type": "dimension", "$value": "150ms" },
    "base": { "$type": "dimension", "$value": "200ms" },
    "slow": { "$type": "dimension", "$value": "300ms" }
  },

  "easing": {
    "default": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
    "bounce": { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1] },
    "in-out": { "$type": "cubicBezier", "$value": [0.65, 0, 0.35, 1] }
  },

  "layout": {
    "containerMax": { "$type": "dimension", "$value": "1280px" }
  },

  "dark": {
    "description": "Dark mode overrides — Ocean Depths",
    "color": {
      "primary": {
        "50": { "$type": "color", "$value": "#0f2a33" },
        "100": { "$type": "color", "$value": "#19333d" },
        "200": { "$type": "color", "$value": "#2c7575" },
        "300": { "$type": "color", "$value": "#379999" },
        "400": { "$type": "color", "$value": "#59c0c0", "description": "CTA default (dark)" },
        "500": { "$type": "color", "$value": "#62c4c4" },
        "600": { "$type": "color", "$value": "#80d1d1" },
        "700": { "$type": "color", "$value": "#a9dbdb" },
        "800": { "$type": "color", "$value": "#c5e7e7" },
        "900": { "$type": "color", "$value": "#e1f0f0" },
        "950": { "$type": "color", "$value": "#f2f7f4" }
      },
      "surface": {
        "background": { "$type": "color", "$value": "#1b2532" },
        "elevated": { "$type": "color", "$value": "#212d3b" },
        "sunken": { "$type": "color", "$value": "#141e2a" },
        "highlight": { "$type": "color", "$value": "#283645" },
        "inset": { "$type": "color", "$value": "#0f161f" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "#f3f7f4" },
        "secondary": { "$type": "color", "$value": "#abd9d9" },
        "tertiary": { "$type": "color", "$value": "#86aab6" },
        "muted": { "$type": "color", "$value": "#6c919d" },
        "on-primary": { "$type": "color", "$value": "#1b2532" },
        "link": { "$type": "color", "$value": "#4bbebe" },
        "link-hover": { "$type": "color", "$value": "#6ccccc" }
      },
      "semantic": {
        "success": { "$type": "color", "$value": "#4ccbcb" },
        "warning": { "$type": "color", "$value": "#dbb660" },
        "emergency": { "$type": "color", "$value": "#db7373" },
        "info": { "$type": "color", "$value": "#5fa3c4" }
      },
      "border": {
        "default": { "$type": "color", "$value": "#293a4c" },
        "subtle": { "$type": "color", "$value": "#212d3b" },
        "focus": { "$type": "color", "$value": "#2c7575" }
      },
      "terminal": {
        "bg": { "$type": "color", "$value": "#0f161f" },
        "text": { "$type": "color", "$value": "#f3f7f4" },
        "prompt": { "$type": "color", "$value": "#2c7575" },
        "cursor": { "$type": "color", "$value": "#2c7575" },
        "comment": { "$type": "color", "$value": "#7197a6" },
        "keyword": { "$type": "color", "$value": "#62c4c4" },
        "string": { "$type": "color", "$value": "#7ad1a6" }
      }
    },
    "shadow": {
      "sm": {
        "$type": "shadow",
        "$value": { "offsetX": 0, "offsetY": 1, "blur": 2, "color": "#000000", "opacity": 0.2 }
      },
      "md": {
        "$type": "shadow",
        "$value": { "offsetX": 0, "offsetY": 4, "blur": 12, "color": "#000000", "opacity": 0.25 }
      },
      "lg": {
        "$type": "shadow",
        "$value": { "offsetX": 0, "offsetY": 12, "blur": 40, "color": "#000000", "opacity": 0.35 }
      },
      "xl": {
        "$type": "shadow",
        "$value": { "offsetX": 0, "offsetY": 24, "blur": 60, "color": "#000000", "opacity": 0.45 }
      }
    }
  }
}
