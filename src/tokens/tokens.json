      "$type": "string",
      "$value": "clamp(2.5rem, 5vw, 4rem)"
    },
    "h1": {
      "$type": "string",
      "$value": "clamp(2rem, 4vw, 3rem)"
    },
    "h2": {
      "$type": "string",
      "$value": "clamp(1.5rem, 3vw, 2.25rem)"
