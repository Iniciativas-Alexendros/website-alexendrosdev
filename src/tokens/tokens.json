    "default": {
      "$type": "cubicBezier",
      "$value": [0.4, 0, 0.2, 1]
    },
    "bounce": {
      "$type": "cubicBezier",
      "$value": [0.34, 1.56, 0.64, 1]
    },
    "in-out": {
      "$type": "cubicBezier",
      "$value": [0.65, 0, 0.35, 1]
    }
  },
  "layout": {
    "containerMax": {
      "$type": "dimension",
