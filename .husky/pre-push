#!/usr/bin/env sh
# Pre-push: valida que el código pase typecheck, lint y tests antes de llegar a CI.
# Detiene el push si cualquier comando falla.

set -e

echo "▸ branch name..."
bash .husky/branch-name-check.sh

echo "▸ typecheck..."
pnpm typecheck

echo "▸ lint..."
pnpm lint

echo "▸ test:coverage..."
pnpm test:coverage

echo "▸ validate tokens..."
bash scripts/validate-tokens.sh

echo "✓ pre-push OK"
